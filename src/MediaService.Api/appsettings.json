{
  "ConnectionStrings": {
    "Default": "Host=localhost;Port=5432;Database=media_db;Username=postgres;Password=postgres"
  },
  "Storage": {
    "Provider": "Minio",
   
    "BasePath": "uploads",
    "PublicBaseUrl": "http://localhost:5000/media-files",

    "Minio": {
      "Endpoint": "localhost:9000",
      "AccessKey": "admin",
      "SecretKey": "password123",
      "Bucket": "media",
      "UseSSL": false
    }
  }, 
  "Auth": {
    "Authority": "https://localhost:7001",
    "Audience": "media-api"
  },
  "Serilog": {
    "MinimumLevel": "Information",
    "WriteTo": [
      {
        "Name": "Console"
      }
    ]
  }
}
